# Committed safe defaults. Never put secrets here.
# Layered env order (last wins):
#   .env.base  (this file, committed)
#   .env.devkeys  (gitignored)
#   .env.personal  (gitignored)

# ---- Daemon ----
RUST_LOG=info,anima=debug,sqlx=warn
ANIMA_BACKEND=openai
ANIMA_DEBUG_BIND=127.0.0.1:7000

# ---- Postgres + pgvector ----
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_USER=anima
POSTGRES_PASSWORD=anima
POSTGRES_DB=anima
DATABASE_URL=postgres://anima:anima@127.0.0.1:5433/anima

# ---- Audio (cpal) ----
# Empty = use system default input/output device.
ANIMA_INPUT_DEVICE=
ANIMA_OUTPUT_DEVICE=
ANIMA_SAMPLE_RATE=24000

# ---- Providers ----
# Default model IDs. Keys live in .env.devkeys.
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
GEMINI_LIVE_MODEL=gemini-2.0-flash-live
